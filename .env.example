############################################
# CyberYozh API
############################################

# API key from https://app.cyberyozh.com/api-access/
CYBERYOZH_API_KEY=

# Base URL for CyberYozh API
CYBERYOZH_BASE_URL=https://app.cyberyozh.com


############################################
# Service
############################################

# FastAPI / Uvicorn
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO


############################################
# Playwright / Browser
############################################

# Run browser in headless mode
HEADLESS=true

# Block images, fonts, media (faster + cheaper traffic)
BLOCK_ASSETS=true

# Default navigation timeout (ms)
REQUEST_TIMEOUT_MS=30000

# Max attempts per scrape request when a failure looks like a proxy issue
# (used only when a proxy is selected; direct connections never retry).
MAX_RETRIES=5

# Prevent WebRTC from leaking the real IP around the proxy. Set to false
# only if you need working WebRTC (video chat / RTCPeerConnection) inside
# scraped pages.
WEBRTC_BLOCK=true



############################################
# Worker pool
############################################

# Number of browser worker processes
WORKERS=2

# Max jobs waiting in memory queue
QUEUE_MAXSIZE=200

# Max time API waits for worker result (ms)
JOB_TIMEOUT_MS=45000
