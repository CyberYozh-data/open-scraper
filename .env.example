############################################
# CyberYozh API
############################################

# API key from https://app.cyberyozh.com/api-access/
CYBERYOZH_API_KEY=

# Base URL for CyberYozh API
CYBERYOZH_BASE_URL=https://app.cyberyozh.com


############################################
# Service
############################################

# FastAPI / Uvicorn
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO


############################################
# Playwright / Browser
############################################

# Run browser in headless mode
HEADLESS=true

# Block images, fonts, media (faster + cheaper traffic)
BLOCK_ASSETS=true

# Default navigation timeout (ms)
REQUEST_TIMEOUT_MS=30000

# Number of retries on timeout / captcha / block
MAX_RETRIES=2

# Max concurrent scrape requests per service instance
MAX_CONCURRENCY=3


############################################
# Debug / Artifacts
############################################

# Save raw HTML to OUT_DIR/<request_id>.html
DEBUG_SAVE_HTML=false

# Save screenshot to OUT_DIR/<request_id>.png
DEBUG_SAVE_SCREENSHOT=false

# Directory for debug artifacts
OUT_DIR=out


############################################
# Development helpers
############################################

# If true, allows running without proxies even if proxy_type != none
# (optional, useful for local debugging; not wired by default)
#ALLOW_NO_PROXY=false


############################################
# Worker pool
############################################

# Number of browser worker processes
WORKERS=2

# Max jobs waiting in memory queue
QUEUE_MAXSIZE=200

# Max time API waits for worker result (ms)
JOB_TIMEOUT_MS=45000
